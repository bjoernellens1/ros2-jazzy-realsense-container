# Compose runtime: auto, podman, or docker.
# The scripts auto-detect by default.
CONTAINER_ENGINE=auto

# ROS
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# GUI
DISPLAY=:0
QT_X11_NO_MITSHM=1
LIBGL_ALWAYS_SOFTWARE=0

# Camera defaults. You can override here without editing scripts.
CAMERA_NAME=camera
DEPTH_PROFILE=640x480x15
COLOR_PROFILE=640x480x15
ENABLE_POINTCLOUD=false
ALIGN_DEPTH=true
INITIAL_RESET=true
ENABLE_IMU=true
UNITE_IMU_METHOD=2

# Recording
ROSBAG_STORAGE=mcap

# Offline pseudo-GT RAM workspace size. Increase on cluster nodes for long bags.
PSEUDO_GT_SHM_SIZE=32gb
